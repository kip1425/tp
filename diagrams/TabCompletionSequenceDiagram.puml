@startuml
!include style.puml
skinparam ArrowFontStyle plain

actor User as User USER_COLOR

box UI UI_COLOR_T1
participant ":CommandBox" as CommandBox UI_COLOR
end box

box Logic LOGIC_COLOR_T1
participant ":TabCompleter" as TabCompleter LOGIC_COLOR
end box

User -> CommandBox : press Tab\n(current text: "filter ")
activate CommandBox

note right of CommandBox
  No current candidates —
  compute a fresh list
end note

CommandBox -> TabCompleter : complete("filter ")
activate TabCompleter

note right of TabCompleter
  Recognises "filter" command
  with trailing space →
  suggests field prefixes
end note

TabCompleter --> CommandBox : ["filter g/", "filter m/", "filter s/"]
deactivate TabCompleter

CommandBox -> CommandBox : filter out candidates\nidentical to current text

CommandBox -> CommandBox : apply first candidate\n("filter g/") to TextField

CommandBox --> User : Tab event consumed;\ncommand box shows "filter g/"
deactivate CommandBox

@enduml
